{
  "name": "pi-content-offloader",
  "version": "0.1.10",
  "description": "Auto-offloads large user inputs in pi to a temporary directory — explicit $offload markers and auto-detect for paste content >2KB",
  "keywords": [
    "pi-package",
    "pi-extension",
    "offload",
    "pi"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "scripts": {
    "build": "bun run build.ts",
    "publish": "bun run ./build.ts && cd dist && bunx npm publish --access public",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "fix": "biome check --write .",
    "check": "tsc --noEmit",
    "clean": "rm -rf node_modules dist"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "image": "https://raw.githubusercontent.com/snorreks/pi-content-offloader/master/assets/thumbnail.jpg",
    "video": "https://raw.githubusercontent.com/snorreks/pi-content-offloader/master/assets/showcase.mp4"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/snorreks/pi-content-offloader.git"
  },
  "bugs": {
    "url": "https://github.com/snorreks/pi-content-offloader/issues"
  },
  "homepage": "https://github.com/snorreks/pi-content-offloader#readme"
}
